# Visual Studio cache/user files
.vs/
**/.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.VC.db
*.VC.opendb
*.opendb
ipch/
*.ipch

# Build output directories
[Dd]ebug/
[Rr]elease/
x64/
x86/
ARM/
ARM64/
# Keep generated runtime files ignored, but version required runtime DLLs.
[Bb]in/*
![Bb]in/*.dll
[Oo]bj/
obj/
[Oo]ut/

# C/C++ intermediate files
*.o
*.d
*.obj
*.iobj
*.idb
*.ipdb
*.ilk
*.pdb
*.pch
*.tlog
*.lastbuildstate
*.log
*.tmp
*.exe.recipe
*.rsp

# Binary outputs
*.exe
*.exp

# Per-user project settings
*.vcxproj.user
